---
import { getLangFromUrl, useTranslations, localizedPath, type Lang } from '../i18n/ui';

interface Props {
  slug: 'contractorpass' | 'shiftlog' | 'portops';
  nameKey: 'cp.name' | 'sl.name' | 'po.name';
  taglineKey: 'cp.tagline' | 'sl.tagline' | 'po.tagline';
  shortKey: 'cp.short' | 'sl.short' | 'po.short';
  accent: 'brand' | 'emerald' | 'amber';
  icon: 'card' | 'clipboard' | 'ship';
}

const { slug, nameKey, taglineKey, shortKey, accent, icon } = Astro.props;
const lang: Lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const accentStyles = {
  brand: 'from-brand-500 to-brand-700',
  emerald: 'from-emerald-500 to-teal-700',
  amber: 'from-amber-500 to-orange-700',
};
---

<article class="group relative bg-white border border-slate-200 rounded-2xl p-6 hover:shadow-xl hover:border-brand-300 transition-all duration-300 flex flex-col">
  <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${accentStyles[accent]} flex items-center justify-center text-white mb-5`}>
    {icon === 'card' && (
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75A2.25 2.25 0 016 4.5h12a2.25 2.25 0 012.25 2.25v10.5A2.25 2.25 0 0118 19.5H6a2.25 2.25 0 01-2.25-2.25V6.75z"/>
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9.75h16.5M9 15h3"/>
      </svg>
    )}
    {icon === 'clipboard' && (
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5.25h6a2.25 2.25 0 012.25 2.25v.75h.75A2.25 2.25 0 0120.25 10.5v8.25A2.25 2.25 0 0118 21H6a2.25 2.25 0 01-2.25-2.25V10.5A2.25 2.25 0 016 8.25h.75V7.5A2.25 2.25 0 019 5.25z"/>
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6M9 15.75h6"/>
      </svg>
    )}
    {icon === 'ship' && (
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 18.75s1.5 1.5 4.125 1.5 3.75-1.5 4.125-1.5 1.5 1.5 4.125 1.5 4.125-1.5 4.125-1.5M4.5 15l1.5-6h12l1.5 6M10.5 9V4.5h3V9M12 9v9"/>
      </svg>
    )}
  </div>

  <h3 class="text-xl font-bold text-slate-900">{t(nameKey)}</h3>
  <p class="text-sm font-medium text-brand-700 mt-0.5">{t(taglineKey)}</p>
  <p class="mt-3 text-sm text-slate-600 leading-relaxed flex-1">{t(shortKey)}</p>

  <a
    href={localizedPath(lang, `/${slug}`)}
    class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-700 group-hover:text-brand-900"
  >
    {t('card.learnmore')}
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
    </svg>
  </a>
</article>
