---
import { getLangFromUrl, useTranslations, localizedPath, type Lang } from '../i18n/ui';
import AppCard from './AppCard.astro';

const lang: Lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative overflow-hidden bg-gradient-to-br from-brand-900 via-brand-800 to-brand-700 text-white">
  <div class="absolute inset-0 opacity-10" aria-hidden="true">
    <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
      <defs><pattern id="gridhome" width="48" height="48" patternUnits="userSpaceOnUse"><path d="M 48 0 L 0 0 0 48" fill="none" stroke="white" stroke-width="0.5"/></pattern></defs>
      <rect width="100%" height="100%" fill="url(#gridhome)"/>
    </svg>
  </div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32">
    <div class="max-w-3xl">
      <div class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-white/15 backdrop-blur-sm">
        {t('hero.badge')}
      </div>
      <h1 class="mt-5 text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-tight">
        {t('hero.title')}
      </h1>
      <p class="mt-6 text-lg lg:text-xl text-white/90 leading-relaxed max-w-2xl">
        {t('hero.subtitle')}
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a href="#products" class="inline-flex items-center px-6 py-3 bg-white text-brand-900 font-semibold rounded-lg hover:bg-slate-100 transition-colors shadow-lg">
          {t('hero.cta.primary')}
        </a>
        <a href={localizedPath(lang, lang === 'tr' ? '/iletisim' : '/contact')} class="inline-flex items-center px-6 py-3 bg-brand-600/50 backdrop-blur-sm border border-white/30 text-white font-semibold rounded-lg hover:bg-brand-600/70 transition-colors">
          {t('hero.cta.secondary')}
        </a>
      </div>
    </div>
  </div>
</section>

<section id="products" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-slate-900">{t('products.title')}</h2>
    <p class="mt-4 text-lg text-slate-600">{t('products.subtitle')}</p>
  </div>

  <div class="mt-14 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <AppCard slug="contractorpass" nameKey="cp.name" taglineKey="cp.tagline" shortKey="cp.short" accent="brand" icon="card" />
    <AppCard slug="shiftlog" nameKey="sl.name" taglineKey="sl.tagline" shortKey="sl.short" accent="emerald" icon="clipboard" />
    <AppCard slug="portops" nameKey="po.name" taglineKey="po.tagline" shortKey="po.short" accent="amber" icon="ship" />
  </div>
</section>

<section class="bg-slate-50 py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900">{t('why.title')}</h2>
    </div>
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {[1,2,3,4].map((i) => (
        <div class="bg-white rounded-2xl p-6 border border-slate-200">
          <div class="w-10 h-10 rounded-lg bg-brand-100 flex items-center justify-center text-brand-700 mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="font-semibold text-slate-900">{t(`why.${i}.title` as any)}</h3>
          <p class="mt-2 text-sm text-slate-600 leading-relaxed">{t(`why.${i}.desc` as any)}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="bg-gradient-to-br from-brand-900 to-brand-700 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold">{t('cta.title')}</h2>
    <p class="mt-3 text-lg text-white/85">{t('cta.subtitle')}</p>
    <a
      href={localizedPath(lang, lang === 'tr' ? '/iletisim' : '/contact')}
      class="mt-8 inline-flex items-center px-8 py-3 bg-white text-brand-900 font-semibold rounded-lg hover:bg-slate-100 transition-colors shadow-lg"
    >
      {t('cta.button')}
    </a>
  </div>
</section>
