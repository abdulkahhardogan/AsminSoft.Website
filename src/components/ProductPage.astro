---
import { getLangFromUrl, useTranslations, localizedPath, type Lang } from '../i18n/ui';

interface Feature {
  titleKey: string;
  descKey: string;
}

interface Props {
  heroTitleKey: string;
  heroSubtitleKey: string;
  problemTitleKey: string;
  problemKeys: string[];
  solutionTitleKey: string;
  solutionDescKey: string;
  featuresTitleKey: string;
  features: Feature[];
  whoTitleKey: string;
  whoListKey: string;
  accent: 'brand' | 'emerald' | 'amber';
  productName: string;
}

const props = Astro.props;
const lang: Lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const gradients = {
  brand: 'from-brand-700 via-brand-600 to-brand-800',
  emerald: 'from-emerald-700 via-teal-700 to-emerald-900',
  amber: 'from-amber-600 via-orange-600 to-amber-800',
};

// @ts-ignore - dynamic key lookup
const tAny = (k: string): string => t(k as any);
---

<section class={`relative overflow-hidden bg-gradient-to-br ${gradients[props.accent]} text-white`}>
  <div class="absolute inset-0 opacity-10" aria-hidden="true">
    <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg"><defs><pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse"><path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="0.5"/></pattern></defs><rect width="100%" height="100%" fill="url(#grid)"/></svg>
  </div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="flex flex-col lg:flex-row items-center gap-12">
      <div class="flex-1 max-w-3xl">
        <div class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-white/15 backdrop-blur-sm">
          {props.productName}
        </div>
        <h1 class="mt-4 text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-tight">
          {tAny(props.heroTitleKey)}
        </h1>
        <p class="mt-6 text-lg lg:text-xl text-white/90 leading-relaxed">
          {tAny(props.heroSubtitleKey)}
        </p>
        <div class="mt-8">
          <a
            href={localizedPath(lang, lang === 'tr' ? '/iletisim' : '/contact')}
            class="inline-flex items-center px-6 py-3 bg-white text-slate-900 font-semibold rounded-lg hover:bg-slate-100 transition-colors shadow-lg"
          >
            {t('cta.button')}
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </a>
        </div>
      </div>
      <slot name="hero-visual" />
    </div>
  </div>
</section>

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
  <div class="max-w-3xl">
    <h2 class="text-3xl sm:text-4xl font-bold text-slate-900">{tAny(props.problemTitleKey)}</h2>
    <ul class="mt-8 space-y-4">
      {props.problemKeys.map((key) => (
        <li class="flex gap-3 items-start">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 flex-shrink-0 text-red-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0 3.75h.008v.008H12v-.008zm0-13.5C6.477 2.25 2.25 6.477 2.25 12S6.477 21.75 12 21.75 21.75 17.523 21.75 12 17.523 2.25 12 2.25z"/>
          </svg>
          <span class="text-lg text-slate-700">{tAny(key)}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<section class="bg-slate-50 py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900">{tAny(props.featuresTitleKey)}</h2>
    </div>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {props.features.map((f) => (
        <div class="bg-white rounded-2xl p-6 border border-slate-200 hover:shadow-md transition-shadow">
          <div class={`w-10 h-10 rounded-lg bg-gradient-to-br ${gradients[props.accent]} flex items-center justify-center text-white mb-4`}>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-900">{tAny(f.titleKey)}</h3>
          <p class="mt-2 text-sm text-slate-600 leading-relaxed">{tAny(f.descKey)}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
  <div class="max-w-3xl">
    <h2 class="text-3xl sm:text-4xl font-bold text-slate-900">{tAny(props.whoTitleKey)}</h2>
    <p class="mt-4 text-lg text-slate-700 leading-relaxed">{tAny(props.whoListKey)}</p>
  </div>
</section>

<section class="bg-gradient-to-br from-brand-900 to-brand-700 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold">{t('cta.title')}</h2>
    <p class="mt-3 text-lg text-white/85">{t('cta.subtitle')}</p>
    <a
      href={localizedPath(lang, lang === 'tr' ? '/iletisim' : '/contact')}
      class="mt-8 inline-flex items-center px-8 py-3 bg-white text-brand-900 font-semibold rounded-lg hover:bg-slate-100 transition-colors shadow-lg"
    >
      {t('cta.button')}
    </a>
  </div>
</section>
