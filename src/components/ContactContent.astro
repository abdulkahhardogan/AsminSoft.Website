---
import { getLangFromUrl, useTranslations, type Lang } from '../i18n/ui';

const lang: Lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="bg-gradient-to-br from-brand-900 to-brand-700 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-24">
    <h1 class="text-4xl sm:text-5xl font-extrabold">{t('contact.title')}</h1>
    <p class="mt-4 text-xl text-white/85 max-w-3xl">{t('contact.lead')}</p>
  </div>
</section>

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20 grid grid-cols-1 lg:grid-cols-3 gap-10">
  <div class="lg:col-span-2">
    <form action="mailto:info@asminsoft.com" method="post" enctype="text/plain" class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div class="sm:col-span-1">
        <label class="block text-sm font-medium text-slate-700 mb-1.5">{t('contact.form.name')}</label>
        <input type="text" name="name" required class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" />
      </div>
      <div class="sm:col-span-1">
        <label class="block text-sm font-medium text-slate-700 mb-1.5">{t('contact.form.company')}</label>
        <input type="text" name="company" class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" />
      </div>
      <div class="sm:col-span-1">
        <label class="block text-sm font-medium text-slate-700 mb-1.5">{t('contact.form.email')}</label>
        <input type="email" name="email" required class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" />
      </div>
      <div class="sm:col-span-1">
        <label class="block text-sm font-medium text-slate-700 mb-1.5">{t('contact.form.phone')}</label>
        <input type="tel" name="phone" class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" />
      </div>
      <div class="sm:col-span-2">
        <label class="block text-sm font-medium text-slate-700 mb-1.5">{t('contact.form.product')}</label>
        <select name="product" class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 bg-white">
          <option>{t('contact.form.product.any')}</option>
          <option>ContractorPass</option>
          <option>ShiftLog</option>
          <option>PortOps</option>
        </select>
      </div>
      <div class="sm:col-span-2">
        <label class="block text-sm font-medium text-slate-700 mb-1.5">{t('contact.form.message')}</label>
        <textarea name="message" rows="5" required class="w-full px-4 py-2.5 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500"></textarea>
      </div>
      <div class="sm:col-span-2">
        <button type="submit" class="inline-flex items-center px-6 py-3 bg-brand-700 text-white font-semibold rounded-lg hover:bg-brand-800 transition-colors shadow">
          {t('contact.form.submit')}
        </button>
      </div>
    </form>
  </div>

  <aside class="space-y-5">
    <div class="bg-slate-50 rounded-2xl p-6">
      <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider">{t('contact.email.label')}</div>
      <div class="mt-1 text-lg font-medium text-slate-900">info@asminsoft.com</div>
    </div>
    <div class="bg-slate-50 rounded-2xl p-6">
      <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider">{t('contact.location.label')}</div>
      <div class="mt-1 text-lg font-medium text-slate-900">{t('contact.location.value')}</div>
    </div>
  </aside>
</section>
