---
interface Props {
  class?: string;
  variant?: 'light' | 'dark';
}

const { class: className = 'w-8 h-8', variant = 'light' } = Astro.props;
const bgStart = variant === 'dark' ? '#ffffff' : '#2f50ff';
const bgEnd = variant === 'dark' ? '#dbeafe' : '#1a28b8';
const petal = variant === 'dark' ? '#1a28b8' : '#ffffff';
const petalSoft = variant === 'dark' ? '#4264ff' : '#eaf0ff';
const center = variant === 'dark' ? '#f5b642' : '#ffd166';
const leaf = variant === 'dark' ? '#11a36a' : '#7ee2aa';
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 64 64"
  role="img"
  aria-label="AsminTech çiçek ikonu"
  class={className}
>
  <defs>
    <linearGradient id="brandIconBg" x1="10" y1="6" x2="56" y2="58" gradientUnits="userSpaceOnUse">
      <stop offset="0" stop-color={bgStart} />
      <stop offset="1" stop-color={bgEnd} />
    </linearGradient>
  </defs>
  <rect width="64" height="64" rx="14" fill="url(#brandIconBg)" />
  <path d="M32 38c-5-9-5-17 0-24 5 7 5 15 0 24Z" fill={petal} />
  <path d="M32 38c-9-5-13-12-12-20 8 1 14 6 12 20Z" fill={petalSoft} />
  <path d="M32 38c-10 1-17-2-21-9 8-4 15-2 21 9Z" fill={petal} />
  <path d="M32 38c6-8 13-11 21-9-4 7-11 10-21 9Z" fill={petalSoft} />
  <path d="M32 38c-2-10 2-16 12-20 1 8-3 15-12 20Z" fill={petal} />
  <circle cx="32" cy="36" r="5.2" fill={center} />
  <path d="M31 41c-2 7-6 11-13 12 1-7 6-11 13-12Z" fill={leaf} />
  <path d="M34 41c5 3 8 8 8 14-6-2-10-6-8-14Z" fill={leaf} opacity=".92" />
</svg>
