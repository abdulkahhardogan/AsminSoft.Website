---
import { getLangFromUrl, useTranslations, localizedPath, type Lang } from '../i18n/ui';
import BrandIcon from './BrandIcon.astro';

const lang: Lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="bg-slate-900 text-slate-300 mt-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="md:col-span-2">
        <div class="flex items-center gap-2 font-bold text-xl text-white">
          <BrandIcon class="w-8 h-8 shrink-0" variant="dark" />
          AsminTech
        </div>
        <p class="mt-3 text-sm text-slate-400 max-w-sm">{t('footer.tagline')}</p>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider">{t('footer.products')}</h4>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href={localizedPath(lang, '/contractorpass')} class="hover:text-white">ContractorPass</a></li>
          <li><a href={localizedPath(lang, '/shiftlog')} class="hover:text-white">ShiftLog</a></li>
          <li><a href={localizedPath(lang, '/portops')} class="hover:text-white">PortOps</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider">{t('footer.company')}</h4>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href={localizedPath(lang, lang === 'tr' ? '/hakkimizda' : '/about')} class="hover:text-white">{t('nav.about')}</a></li>
          <li><a href={localizedPath(lang, lang === 'tr' ? '/iletisim' : '/contact')} class="hover:text-white">{t('nav.contact')}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-slate-800 flex flex-col sm:flex-row justify-between gap-3 text-xs text-slate-500">
      <div>© {year} AsminTech. {t('footer.rights')}</div>
      <div>Türkiye</div>
    </div>
  </div>
</footer>
