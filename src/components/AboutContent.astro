---
import { getLangFromUrl, useTranslations, localizedPath, type Lang } from '../i18n/ui';

const lang: Lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="bg-gradient-to-br from-brand-900 to-brand-700 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-24">
    <h1 class="text-4xl sm:text-5xl font-extrabold">{t('about.title')}</h1>
    <p class="mt-4 text-xl text-white/85 max-w-3xl">{t('about.lead')}</p>
  </div>
</section>

<section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20 prose prose-slate prose-lg">
  <p>{t('about.p1')}</p>
  <p>{t('about.p2')}</p>
</section>

<section class="bg-slate-50 py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-slate-900">{t('about.values.title')}</h2>
    <div class="mt-10 grid grid-cols-1 md:grid-cols-3 gap-6">
      {[1,2,3].map((i) => (
        <div class="bg-white rounded-2xl p-6 border border-slate-200">
          <h3 class="font-semibold text-lg text-slate-900">{t(`about.v${i}.title` as any)}</h3>
          <p class="mt-2 text-slate-600 leading-relaxed">{t(`about.v${i}.desc` as any)}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="bg-gradient-to-br from-brand-900 to-brand-700 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold">{t('cta.title')}</h2>
    <a
      href={localizedPath(lang, lang === 'tr' ? '/iletisim' : '/contact')}
      class="mt-8 inline-flex items-center px-8 py-3 bg-white text-brand-900 font-semibold rounded-lg hover:bg-slate-100 transition-colors shadow-lg"
    >
      {t('cta.button')}
    </a>
  </div>
</section>
